1) Kafka Notes

-- create topic

kafka-topics \
  --create \
  --topic events \
  --bootstrap-server localhost:9092 \
  --partitions 3 \
  --replication-factor 1

--- describe topic

kafka-topics \
  --describe \
  --topic events \
  --bootstrap-server localhost:9092

--- check consumer group partitions distributions

kafka-consumer-groups \
  --bootstrap-server localhost:9092 \
  --describe \
  --group flink-group



2) Docker Notes

  docker-compose stop jobmanager taskmanager 

  docker-compose build jobmanager taskmanager

  docker-compose up -d jobmanager taskmanager

----- Run ---

add topics events , events_parsed
go to job_manager container and run 
    flink run -py jobs/flink_stream_job.py

